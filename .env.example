# Copie para ".env" (sem o .example) e preencha antes de "docker compose up".
# No Coolify, essas mesmas variáveis também podem ser geridas pela UI do projeto.

# Pelo menos UMA chave de IA é obrigatória. Ordem de fallback quando uma bate a
# cota gratuita do dia: gemini > groq > nvidia.
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Fonte do Google Maps: o padrão é o scraper (gosom/google-maps-scraper) -
# no servidor a imagem já baixa o binário nativo Linux dele, de graça, sem
# precisar de chave nem navegador manual. PLACES_API_KEY só é necessária se
# você preferir trocar pra fonte "Places API" (Configurações -> Fonte de
# dados do Maps), que é paga por consulta acima da cota gratuita do Google.
PLACES_API_KEY=

# Opcional: diagnóstico de sites (PageSpeed Insights)
PAGESPEED_API_KEY=

# Opcional: nível de log (DEBUG, INFO, WARNING, ERROR)
PROSPECCAO_LOG_LEVEL=INFO

# Login (Basic Auth) na frente de todo o app - o ProspectOS não tem tela de
# login própria, então isso é obrigatório antes de expor a URL publicamente.
# Senha em texto puro mesmo - o container do proxy gera o hash bcrypt sozinho
# ao subir (evita colar um hash com "$" em UI/`.env`, que quebra fácil com o
# escaping de "$" do docker-compose). Só evite usar "$" na própria senha (se
# usar, tem que dobrar: "$" -> "$$"); qualquer outro caractere é de boa.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=
